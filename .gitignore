# ============================================================================
*.pt
*.pth
*.ckpt
*.onnx
*.tflite
*.engine
*.mlmodel
*.pb
*.h5
!models/person_best.pt

# ============================================================================
# 训练输出
# ============================================================================
runs/
output/
results/
logs/
*.log

# ============================================================================
# 密钥与凭证
