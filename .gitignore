kaggle.json
*.json.key
*.key
.env
.env.local
.env.*.local
secrets/
credentials/
.deploy_remote

# ============================================================================
# 敏感配置（含 API Key / 密码）
# ============================================================================
config.secrets.yaml
config.local.yaml

# ============================================================================
# 运行时数据
# ============================================================================
data/screenshots/
data/alerts/

# ============================================================================
