# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/

# ============================================================================
# 数据集（体积大，本地保留）
# ============================================================================
datasets/
dataset/
data/images/
data/labels/
data/*.cache

# 压缩包
*.zip
*.tar
*.tar.gz
*.rar

# ============================================================================
