# ============================================================
# YOLO 安防监控系统 - 环境变量模板
# 复制此文件为 .env 并填入真实值
# ============================================================

# ── 数据库 ──
YOLO_DATABASE_HOST=localhost
YOLO_DATABASE_PORT=3306
YOLO_DATABASE_USER=root
YOLO_DATABASE_PASSWORD=your_database_password_here
YOLO_DATABASE_NAME=safecam

# ── Redis（可选） ──
YOLO_REDIS_HOST=localhost
YOLO_REDIS_PORT=6379
YOLO_REDIS_PASSWORD=
YOLO_REDIS_DB=0

# ── JWT 认证 ──
YOLO_AUTH_SECRET_KEY=change_me_to_a_random_32_byte_hex_string
YOLO_AUTH_INIT_ADMIN_PASSWORD=your_admin_password_here

# ── 飞书通知（可选） ──
YOLO_FEISHU_ENABLED=false
YOLO_FEISHU_WEBHOOK_URL=
YOLO_FEISHU_APP_ID=
YOLO_FEISHU_APP_SECRET=
YOLO_FEISHU_CHAT_ID=

# ── 企业微信通知（可选） ──
YOLO_WECHAT_WORK_ENABLED=false
YOLO_WECHAT_WORK_WEBHOOK_URL=

# ── 钉钉通知（可选） ──
YOLO_DINGTALK_ENABLED=false
YOLO_DINGTALK_WEBHOOK_URL=

# ── 邮件通知（可选） ──
YOLO_EMAIL_ENABLED=false
YOLO_EMAIL_SMTP_HOST=
YOLO_EMAIL_SMTP_PORT=465
YOLO_EMAIL_USERNAME=
YOLO_EMAIL_PASSWORD=
YOLO_EMAIL_TO_ADDRS=

# ── Webhook 通知（可选） ──
YOLO_WEBHOOK_ENABLED=false
YOLO_WEBHOOK_URL=

# ── 服务器 ──
YOLO_SERVER_HOST=0.0.0.0
YOLO_SERVER_PORT=8000
